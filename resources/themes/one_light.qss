/*
 * =============================================================================
 * ONE LIGHT THEME
 * =============================================================================
 * 
 * Color Palette Reference:
 * -----------------------------------------------------------------------------
 * ACCENT COLORS:
 *   Rosewater:  #dc8a78    Flamingo:   #dd7878    Pink:       #ea76cb
 *   Mauve:      #8839ef    Red:        #e45649    Maroon:     #e64553
 *   Peach:      #fe640b    Yellow:     #c18401    Green:      #50a14f
 *   Teal:       #179299    Sky:        #04a5e5    Sapphire:   #209fb5
 *   Blue:       #4078f2    Lavender:   #a626a4
 * 
 * TEXT COLORS:
 *   Text:       #383a42    (primary text)
 *   Subtext1:   #4f525e    (secondary text)
 *   Subtext0:   #696c77    (tertiary/muted text)
 * 
 * OVERLAY COLORS (for borders, disabled states, etc.):
 *   Overlay2:   #696c77
 *   Overlay1:   #8b8b8d
 *   Overlay0:   #9d9d9f
 * 
 * SURFACE COLORS (for elevated elements):
 *   Surface2:   #a0a1a7
 *   Surface1:   #c4c4c4
 *   Surface0:   #d4d4d4
 * 
 * BASE COLORS (backgrounds):
 *   Base:       #fafafa    (main background)
 *   Mantle:     #f0f0f0    (secondary background)
 *   Crust:      #e5e5e6    (tertiary background)
 * 
 * =============================================================================
 * THEME VARIABLES (adjust these to change the entire theme)
 * =============================================================================
 * 
 * Primary Accent:      Blue (#4078f2)
 * Secondary Accent:    Lavender (#a626a4)
 * Success:             Green (#50a14f)
 * Warning:             Yellow (#c18401)
 * Error/Destructive:   Red (#e45649)
 * 
 * =============================================================================
 */


/* =============================================================================
 * GLOBAL DEFAULTS
 * =============================================================================
 */

* {
    font-family: "Segoe UI", "SF Pro Display", "Helvetica Neue", Arial, sans-serif;
    font-size: 10pt;
}

QWidget {
    background-color: #fafafa;
    color: #383a42;
    selection-background-color: #a626a4;
    selection-color: #fafafa;
}

QWidget:disabled {
    color: #9d9d9f;
}


/* =============================================================================
 * MAIN WINDOW & CONTAINERS
 * =============================================================================
 */

QMainWindow {
    background-color: #fafafa;
}

QMainWindow::separator {
    background-color: #d4d4d4;
    width: 1px;
    height: 1px;
}

QMainWindow::separator:hover {
    background-color: #4078f2;
}

QDialog {
    background-color: #fafafa;
}

QFrame {
    border: none;
}

QFrame[frameShape="4"],  /* HLine */
QFrame[frameShape="5"] { /* VLine */
    background-color: #d4d4d4;
    border: none;
    max-height: 1px;
    max-width: 1px;
}


/* =============================================================================
 * MENU BAR
 * =============================================================================
 */

QMenuBar {
    background-color: #f0f0f0;
    color: #383a42;
    border-bottom: 1px solid #d4d4d4;
    padding: 2px;
}

QMenuBar::item {
    background-color: transparent;
    padding: 6px 10px;
    border-radius: 4px;
    margin: 1px;
}

QMenuBar::item:selected {
    background-color: #d4d4d4;
}

QMenuBar::item:pressed {
    background-color: #c4c4c4;
}


/* =============================================================================
 * MENUS & CONTEXT MENUS
 * =============================================================================
 */

QMenu {
    background-color: #f0f0f0;
    color: #383a42;
    border: 1px solid #d4d4d4;
    border-radius: 8px;
    padding: 4px;
}

QMenu::item {
    padding: 6px 24px 6px 12px;
    border-radius: 4px;
    margin: 2px 4px;
}

QMenu::item:selected {
    background-color: #4078f2;
    color: #fafafa;
}

QMenu::item:disabled {
    color: #9d9d9f;
}

QMenu::separator {
    height: 1px;
    background-color: #d4d4d4;
    margin: 4px 8px;
}

QMenu::icon {
    margin-left: 8px;
}

QMenu::indicator {
    width: 16px;
    height: 16px;
    margin-left: 6px;
}


/* =============================================================================
 * TOOLBAR
 * =============================================================================
 */

QToolBar {
    background-color: #f0f0f0;
    border: none;
    border-bottom: 1px solid #d4d4d4;
    padding: 4px;
    spacing: 4px;
}

QToolBar::separator {
    background-color: #d4d4d4;
    width: 1px;
    margin: 4px 8px;
}

QToolButton {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 6px;
    color: #383a42;
}

QToolButton:hover {
    background-color: #d4d4d4;
}

QToolButton:pressed {
    background-color: #c4c4c4;
}

QToolButton:checked {
    background-color: #a626a4;
    color: #fafafa;
}


/* =============================================================================
 * STATUS BAR
 * =============================================================================
 */

QStatusBar {
    background-color: #f0f0f0;
    color: #4f525e;
    border-top: 1px solid #d4d4d4;
}

QStatusBar::item {
    border: none;
}

QStatusBar QLabel {
    padding: 2px 8px;
    color: #4f525e;
}


/* =============================================================================
 * PUSH BUTTONS
 * =============================================================================
 */

QPushButton {
    background-color: #d4d4d4;
    color: #383a42;
    border: 1px solid #c4c4c4;
    border-radius: 6px;
    padding: 6px 16px;
    min-height: 20px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #c4c4c4;
    border-color: #a0a1a7;
}

QPushButton:pressed {
    background-color: #a0a1a7;
}

QPushButton:disabled {
    background-color: #f0f0f0;
    color: #9d9d9f;
    border-color: #d4d4d4;
}

/* Primary/Default Button */
QPushButton:default,
QPushButton[primary="true"] {
    background-color: #4078f2;
    color: #fafafa;
    border-color: #4078f2;
}

QPushButton:default:hover,
QPushButton[primary="true"]:hover {
    background-color: #5088ff;
    border-color: #5088ff;
}

QPushButton:default:pressed,
QPushButton[primary="true"]:pressed {
    background-color: #3068e2;
}

/* Destructive/Danger Button */
QPushButton[destructive="true"] {
    background-color: #e45649;
    color: #fafafa;
    border-color: #e45649;
}

QPushButton[destructive="true"]:hover {
    background-color: #f46659;
    border-color: #f46659;
}

QPushButton[destructive="true"]:pressed {
    background-color: #d44639;
}

/* Flat/Text Button */
QPushButton:flat {
    background-color: transparent;
    border: none;
}

QPushButton:flat:hover {
    background-color: #d4d4d4;
}


/* =============================================================================
 * LINE EDIT & TEXT INPUTS
 * =============================================================================
 */

QLineEdit {
    background-color: #f0f0f0;
    color: #383a42;
    border: 1px solid #c4c4c4;
    border-radius: 6px;
    padding: 6px 10px;
    selection-background-color: #a626a4;
    selection-color: #fafafa;
}

QLineEdit:hover {
    border-color: #a0a1a7;
}

QLineEdit:focus {
    border-color: #4078f2;
    background-color: #fafafa;
}

QLineEdit:disabled {
    background-color: #e5e5e6;
    color: #9d9d9f;
    border-color: #d4d4d4;
}

QLineEdit[readOnly="true"] {
    background-color: #e5e5e6;
}

/* Placeholder text */
QLineEdit::placeholder {
    color: #8b8b8d;
}


/* =============================================================================
 * TEXT EDIT & PLAIN TEXT EDIT
 * =============================================================================
 */

QTextEdit,
QPlainTextEdit {
    background-color: #fafafa;
    color: #383a42;
    border: 1px solid #c4c4c4;
    border-radius: 6px;
    padding: 6px;
    selection-background-color: #a626a4;
    selection-color: #fafafa;
}

QTextEdit:hover,
QPlainTextEdit:hover {
    border-color: #a0a1a7;
}

QTextEdit:focus,
QPlainTextEdit:focus {
    border-color: #4078f2;
}

QTextEdit:disabled,
QPlainTextEdit:disabled {
    background-color: #e5e5e6;
    color: #9d9d9f;
}


/* =============================================================================
 * SPIN BOX & DOUBLE SPIN BOX
 * =============================================================================
 */

QSpinBox,
QDoubleSpinBox {
    background-color: #f0f0f0;
    color: #383a42;
    border: 1px solid #c4c4c4;
    border-radius: 6px;
    padding: 4px 8px;
    padding-right: 20px;
}

QSpinBox:hover,
QDoubleSpinBox:hover {
    border-color: #a0a1a7;
}

QSpinBox:focus,
QDoubleSpinBox:focus {
    border-color: #4078f2;
    background-color: #fafafa;
}

QSpinBox::up-button,
QDoubleSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 20px;
    border: none;
    border-left: 1px solid #c4c4c4;
    border-top-right-radius: 5px;
    background-color: #d4d4d4;
}

QSpinBox::up-button:hover,
QDoubleSpinBox::up-button:hover {
    background-color: #c4c4c4;
}

QSpinBox::up-button:pressed,
QDoubleSpinBox::up-button:pressed {
    background-color: #a0a1a7;
}

QSpinBox::down-button,
QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 20px;
    border: none;
    border-left: 1px solid #c4c4c4;
    border-bottom-right-radius: 5px;
    background-color: #d4d4d4;
}

QSpinBox::down-button:hover,
QDoubleSpinBox::down-button:hover {
    background-color: #c4c4c4;
}

QSpinBox::down-button:pressed,
QDoubleSpinBox::down-button:pressed {
    background-color: #a0a1a7;
}

QSpinBox::up-arrow,
QDoubleSpinBox::up-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 5px solid #383a42;
    width: 0;
    height: 0;
}

QSpinBox::down-arrow,
QDoubleSpinBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #383a42;
    width: 0;
    height: 0;
}


/* =============================================================================
 * COMBO BOX
 * =============================================================================
 */

QComboBox {
    background-color: #f0f0f0;
    color: #383a42;
    border: 1px solid #c4c4c4;
    border-radius: 6px;
    padding: 6px 10px;
    padding-right: 28px;
    min-height: 20px;
}

QComboBox:hover {
    border-color: #a0a1a7;
}

QComboBox:focus,
QComboBox:on {
    border-color: #4078f2;
}

QComboBox:disabled {
    background-color: #e5e5e6;
    color: #9d9d9f;
    border-color: #d4d4d4;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 24px;
    border: none;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #383a42;
    margin-right: 8px;
}

QComboBox::down-arrow:disabled {
    border-top-color: #9d9d9f;
}

QComboBox QAbstractItemView {
    background-color: #f0f0f0;
    color: #383a42;
    border: 1px solid #d4d4d4;
    border-radius: 6px;
    padding: 4px;
    selection-background-color: #4078f2;
    selection-color: #fafafa;
    outline: none;
}

QComboBox QAbstractItemView::item {
    padding: 6px 10px;
    border-radius: 4px;
    min-height: 20px;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #d4d4d4;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #4078f2;
    color: #fafafa;
}


/* =============================================================================
 * CHECK BOX
 * =============================================================================
 */

QCheckBox {
    color: #383a42;
    spacing: 8px;
}

QCheckBox:disabled {
    color: #9d9d9f;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 2px solid #a0a1a7;
    background-color: #f0f0f0;
}

QCheckBox::indicator:hover {
    border-color: #4078f2;
    background-color: #e5e5e6;
}

QCheckBox::indicator:checked {
    background-color: #4078f2;
    border-color: #4078f2;
    image: none;
}

/* Checkmark using borders */
QCheckBox::indicator:checked::after {
    content: "";
}

QCheckBox::indicator:disabled {
    background-color: #e5e5e6;
    border-color: #c4c4c4;
}

QCheckBox::indicator:checked:disabled {
    background-color: #9d9d9f;
    border-color: #9d9d9f;
}


/* =============================================================================
 * RADIO BUTTON
 * =============================================================================
 */

QRadioButton {
    color: #383a42;
    spacing: 8px;
}

QRadioButton:disabled {
    color: #9d9d9f;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border-radius: 9px;
    border: 2px solid #a0a1a7;
    background-color: #f0f0f0;
}

QRadioButton::indicator:hover {
    border-color: #4078f2;
    background-color: #e5e5e6;
}

QRadioButton::indicator:checked {
    background-color: #4078f2;
    border-color: #4078f2;
}

QRadioButton::indicator:disabled {
    background-color: #e5e5e6;
    border-color: #c4c4c4;
}


/* =============================================================================
 * SLIDER
 * =============================================================================
 */

QSlider::groove:horizontal {
    height: 6px;
    background-color: #d4d4d4;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    width: 18px;
    height: 18px;
    margin: -6px 0;
    background-color: #4078f2;
    border-radius: 9px;
}

QSlider::handle:horizontal:hover {
    background-color: #5088ff;
}

QSlider::handle:horizontal:pressed {
    background-color: #3068e2;
}

QSlider::sub-page:horizontal {
    background-color: #4078f2;
    border-radius: 3px;
}

QSlider::groove:vertical {
    width: 6px;
    background-color: #d4d4d4;
    border-radius: 3px;
}

QSlider::handle:vertical {
    width: 18px;
    height: 18px;
    margin: 0 -6px;
    background-color: #4078f2;
    border-radius: 9px;
}

QSlider::handle:vertical:hover {
    background-color: #5088ff;
}

QSlider::add-page:vertical {
    background-color: #4078f2;
    border-radius: 3px;
}


/* =============================================================================
 * PROGRESS BAR
 * =============================================================================
 */

QProgressBar {
    background-color: #d4d4d4;
    border: none;
    border-radius: 4px;
    height: 8px;
    text-align: center;
    color: #383a42;
}

QProgressBar::chunk {
    background-color: #4078f2;
    border-radius: 4px;
}


/* =============================================================================
 * TAB WIDGET & TAB BAR
 * =============================================================================
 */

QTabWidget::pane {
    border: 1px solid #d4d4d4;
    border-radius: 6px;
    background-color: #fafafa;
    margin-top: -1px;
}

QTabBar {
    background-color: transparent;
}

QTabBar::tab {
    background-color: #f0f0f0;
    color: #4f525e;
    border: 1px solid #d4d4d4;
    border-bottom: none;
    padding: 8px 16px;
    margin-right: 2px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}

QTabBar::tab:hover {
    background-color: #e5e5e6;
    color: #383a42;
}

QTabBar::tab:selected {
    background-color: #fafafa;
    color: #4078f2;
    border-bottom: 2px solid #4078f2;
    margin-bottom: -1px;
}

QTabBar::tab:disabled {
    color: #9d9d9f;
}

/* Close button on tabs */
QTabBar::close-button {
    image: none;
    subcontrol-position: right;
}

QTabBar::close-button:hover {
    background-color: #e45649;
    border-radius: 3px;
}


/* =============================================================================
 * TABLE VIEW & TABLE WIDGET
 * =============================================================================
 */

QTableView,
QTableWidget {
    background-color: #fafafa;
    alternate-background-color: #f0f0f0;
    color: #383a42;
    gridline-color: #d4d4d4;
    border: 1px solid #d4d4d4;
    border-radius: 6px;
    selection-background-color: #a626a4;
    selection-color: #fafafa;
}

QTableView::item,
QTableWidget::item {
    padding: 4px 8px;
    border: none;
}

QTableView::item:hover,
QTableWidget::item:hover {
    background-color: #e5e5e6;
}

QTableView::item:selected,
QTableWidget::item:selected {
    background-color: #a626a4;
    color: #fafafa;
}

QTableView::item:focus,
QTableWidget::item:focus {
    background-color: #4078f2;
    color: #fafafa;
    outline: none;
}

/* Corner button (top-left) */
QTableView QTableCornerButton::section,
QTableWidget QTableCornerButton::section {
    background-color: #f0f0f0;
    border: none;
    border-right: 1px solid #d4d4d4;
    border-bottom: 1px solid #d4d4d4;
}


/* =============================================================================
 * HEADER VIEW (Table & Tree headers)
 * =============================================================================
 */

QHeaderView {
    background-color: #f0f0f0;
    border: none;
}

QHeaderView::section {
    background-color: #f0f0f0;
    color: #383a42;
    padding: 8px 12px;
    border: none;
    border-right: 1px solid #d4d4d4;
    border-bottom: 1px solid #d4d4d4;
    font-weight: 600;
}

QHeaderView::section:hover {
    background-color: #e5e5e6;
}

QHeaderView::section:pressed {
    background-color: #d4d4d4;
}

QHeaderView::section:checked {
    background-color: #c4c4c4;
}

/* Sort indicator */
QHeaderView::up-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 5px solid #4078f2;
    width: 0;
    height: 0;
    margin-left: 4px;
}

QHeaderView::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #4078f2;
    width: 0;
    height: 0;
    margin-left: 4px;
}


/* =============================================================================
 * TREE VIEW & TREE WIDGET
 * =============================================================================
 */

QTreeView,
QTreeWidget {
    background-color: #fafafa;
    alternate-background-color: #f0f0f0;
    color: #383a42;
    border: 1px solid #d4d4d4;
    border-radius: 6px;
    selection-background-color: #a626a4;
    selection-color: #fafafa;
    outline: none;
}

QTreeView::item,
QTreeWidget::item {
    padding: 4px 8px;
    border: none;
}

QTreeView::item:hover,
QTreeWidget::item:hover {
    background-color: #e5e5e6;
}

QTreeView::item:selected,
QTreeWidget::item:selected {
    background-color: #a626a4;
    color: #fafafa;
}

QTreeView::branch {
    background-color: transparent;
}

QTreeView::branch:hover {
    background-color: #e5e5e6;
}

QTreeView::branch:selected {
    background-color: #a626a4;
}


/* =============================================================================
 * LIST VIEW & LIST WIDGET
 * =============================================================================
 */

QListView,
QListWidget {
    background-color: #fafafa;
    alternate-background-color: #f0f0f0;
    color: #383a42;
    border: 1px solid #d4d4d4;
    border-radius: 6px;
    selection-background-color: #a626a4;
    selection-color: #fafafa;
    outline: none;
}

QListView::item,
QListWidget::item {
    padding: 6px 10px;
    border: none;
    border-radius: 4px;
    margin: 1px 4px;
}

QListView::item:hover,
QListWidget::item:hover {
    background-color: #e5e5e6;
}

QListView::item:selected,
QListWidget::item:selected {
    background-color: #a626a4;
    color: #fafafa;
}


/* =============================================================================
 * SCROLL BAR
 * =============================================================================
 */

QScrollBar:horizontal {
    background-color: #f0f0f0;
    height: 12px;
    margin: 0;
    border-radius: 6px;
}

QScrollBar::handle:horizontal {
    background-color: #a0a1a7;
    min-width: 30px;
    border-radius: 6px;
    margin: 2px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #9d9d9f;
}

QScrollBar::handle:horizontal:pressed {
    background-color: #8b8b8d;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
    height: 0;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background-color: transparent;
}

QScrollBar:vertical {
    background-color: #f0f0f0;
    width: 12px;
    margin: 0;
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background-color: #a0a1a7;
    min-height: 30px;
    border-radius: 6px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background-color: #9d9d9f;
}

QScrollBar::handle:vertical:pressed {
    background-color: #8b8b8d;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    width: 0;
    height: 0;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background-color: transparent;
}


/* =============================================================================
 * SPLITTER
 * =============================================================================
 */

QSplitter::handle {
    background-color: #d4d4d4;
}

QSplitter::handle:hover {
    background-color: #4078f2;
}

QSplitter::handle:horizontal {
    width: 2px;
}

QSplitter::handle:vertical {
    height: 2px;
}


/* =============================================================================
 * GROUP BOX
 * =============================================================================
 */

QGroupBox {
    background-color: #f0f0f0;
    border: 1px solid #d4d4d4;
    border-radius: 8px;
    margin-top: 12px;
    padding-top: 8px;
    font-weight: 600;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 0 6px;
    background-color: #f0f0f0;
    color: #383a42;
}


/* =============================================================================
 * LABELS
 * =============================================================================
 */

QLabel {
    color: #383a42;
    background-color: transparent;
}

QLabel:disabled {
    color: #9d9d9f;
}

/* Heading styles - use with setProperty() or object names */
QLabel[heading="1"] {
    font-size: 24pt;
    font-weight: 700;
}

QLabel[heading="2"] {
    font-size: 18pt;
    font-weight: 600;
}

QLabel[heading="3"] {
    font-size: 14pt;
    font-weight: 600;
}

QLabel[subtext="true"] {
    color: #696c77;
}


/* =============================================================================
 * TOOLTIP
 * =============================================================================
 */

QToolTip {
    background-color: #f0f0f0;
    color: #383a42;
    border: 1px solid #d4d4d4;
    border-radius: 6px;
    padding: 6px 10px;
}


/* =============================================================================
 * MESSAGE BOX
 * =============================================================================
 */

QMessageBox {
    background-color: #fafafa;
}

QMessageBox QLabel {
    color: #383a42;
}


/* =============================================================================
 * DOCK WIDGET
 * =============================================================================
 */

QDockWidget {
    color: #383a42;
    titlebar-close-icon: none;
    titlebar-normal-icon: none;
}

QDockWidget::title {
    background-color: #f0f0f0;
    padding: 8px;
    border-bottom: 1px solid #d4d4d4;
}

QDockWidget::close-button,
QDockWidget::float-button {
    background-color: transparent;
    border: none;
    padding: 2px;
}

QDockWidget::close-button:hover,
QDockWidget::float-button:hover {
    background-color: #d4d4d4;
    border-radius: 4px;
}


/* =============================================================================
 * WIZARD
 * =============================================================================
 */

QWizard {
    background-color: #fafafa;
}

QWizard QWidget {
    background-color: #fafafa;
}


/* =============================================================================
 * CALENDAR WIDGET
 * =============================================================================
 */

QCalendarWidget {
    background-color: #fafafa;
}

QCalendarWidget QToolButton {
    color: #383a42;
    background-color: transparent;
    border: none;
    border-radius: 4px;
    padding: 4px;
}

QCalendarWidget QToolButton:hover {
    background-color: #d4d4d4;
}

QCalendarWidget QMenu {
    background-color: #f0f0f0;
}

QCalendarWidget QSpinBox {
    background-color: #f0f0f0;
}

QCalendarWidget QWidget#qt_calendar_navigationbar {
    background-color: #f0f0f0;
    border-bottom: 1px solid #d4d4d4;
}

QCalendarWidget QAbstractItemView:enabled {
    color: #383a42;
    background-color: #fafafa;
    selection-background-color: #4078f2;
    selection-color: #fafafa;
}

QCalendarWidget QAbstractItemView:disabled {
    color: #9d9d9f;
}


/* =============================================================================
 * STACKED WIDGET
 * =============================================================================
 */

QStackedWidget {
    background-color: #fafafa;
}


/* =============================================================================
 * SPECIAL/CUSTOM WIDGET STYLES
 * =============================================================================
 */

/* Project cards (from ProjectSelectionView) */
ProjectCard {
    background-color: #fafafa;
    border: 1px solid #d4d4d4;
    border-radius: 10px;
}

ProjectCard:hover {
    background-color: #f0f0f0;
    border-color: #a0a1a7;
}

/* Error/Warning states */
QLineEdit[error="true"],
QTextEdit[error="true"],
QSpinBox[error="true"],
QComboBox[error="true"] {
    border-color: #e45649;
}

QLabel[error="true"] {
    color: #e45649;
}

QLabel[warning="true"] {
    color: #c18401;
}

QLabel[success="true"] {
    color: #50a14f;
}

/* Links */
QLabel[link="true"] {
    color: #4078f2;
}

QLabel[link="true"]:hover {
    color: #5088ff;
    text-decoration: underline;
}